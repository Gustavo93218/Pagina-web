<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>URBAN FIT · Tienda de ropa</title>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #f7f7f7;
            color: #1e1e1e;
            min-height: 100vh;
        }

        /* HEADER */
        header {
            background: #ffffff;
            padding: 16px 30px;
            box-shadow: 0 2px 16px rgba(0, 0, 0, 0.06);
            position: sticky;
            top: 0;
            z-index: 100;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .logo {
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -0.5px;
            color: #1e1e1e;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .logo span {
            color: #2d7a4a;
        }

        .logo i {
            color: #2d7a4a;
            font-size: 26px;
        }

        nav {
            display: flex;
            gap: 28px;
            font-weight: 600;
        }

        nav a {
            text-decoration: none;
            color: #333;
            font-size: 15px;
            transition: 0.15s;
            border-bottom: 2px solid transparent;
            padding-bottom: 4px;
        }

        nav a:hover {
            color: #2d7a4a;
            border-bottom-color: #2d7a4a;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .header-actions i {
            font-size: 22px;
            color: #333;
            cursor: pointer;
            transition: 0.15s;
        }

        .header-actions i:hover {
            color: #2d7a4a;
        }

        .cart-icon {
            position: relative;
        }

        .cart-badge {
            background: #2d7a4a;
            color: #fff;
            border-radius: 50%;
            padding: 2px 8px;
            font-size: 12px;
            font-weight: 700;
            position: absolute;
            top: -10px;
            right: -12px;
            min-width: 20px;
            text-align: center;
        }

        /* BANNER */
        .banner {
            background: linear-gradient(135deg, #1e2a3a 0%, #2d3f54 100%);
            color: #fff;
            padding: 60px 30px;
            margin: 20px 30px 30px;
            border-radius: 28px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 30px;
        }

        .banner-text h2 {
            font-size: 42px;
            font-weight: 800;
            line-height: 1.2;
        }

        .banner-text h2 span {
            color: #a6e0b3;
        }

        .banner-text p {
            margin-top: 12px;
            font-size: 18px;
            opacity: 0.85;
            max-width: 460px;
        }

        .banner-btn {
            background: #fff;
            color: #1e2a3a;
            border: none;
            padding: 14px 36px;
            border-radius: 60px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            transition: 0.2s;
            display: inline-block;
            margin-top: 18px;
        }

        .banner-btn:hover {
            transform: scale(1.04);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
        }

        .banner-image {
            font-size: 80px;
            opacity: 0.3;
            background: rgba(255, 255, 255, 0.08);
            padding: 30px 40px;
            border-radius: 40px;
        }

        /* CATEGORÍAS */
        .categories {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
            margin: 10px 30px 30px;
        }

        .category-chip {
            background: #fff;
            padding: 12px 28px;
            border-radius: 60px;
            font-weight: 600;
            font-size: 14px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
            cursor: pointer;
            transition: 0.15s;
            border: 1px solid #eaeaea;
        }

        .category-chip:hover {
            border-color: #2d7a4a;
            color: #2d7a4a;
            transform: translateY(-2px);
        }

        .category-chip.active {
            background: #2d7a4a;
            color: #fff;
            border-color: #2d7a4a;
        }

        /* PRODUCTOS */
        .products-section {
            padding: 10px 30px 50px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 12px;
        }

        .section-header h3 {
            font-size: 26px;
            font-weight: 700;
        }

        .section-header span {
            color: #666;
            font-size: 14px;
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 28px;
        }

        .product-card {
            background: #fff;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
            transition: 0.25s;
            padding-bottom: 18px;
            border: 1px solid #f0f0f0;
        }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
        }

        .product-img {
            width: 100%;
            height: 260px;
            background: #eef2f5;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 56px;
            color: #2d7a4a;
            background: linear-gradient(145deg, #f0f4f8, #e2e8ed);
        }

        .product-info {
            padding: 16px 18px 6px;
        }

        .product-info h4 {
            font-size: 17px;
            font-weight: 600;
        }

        .product-info .category-tag {
            font-size: 12px;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 2px;
        }

        .product-info .price {
            font-size: 20px;
            font-weight: 800;
            margin-top: 8px;
            color: #1e1e1e;
        }

        .product-info .price small {
            font-weight: 400;
            font-size: 14px;
            color: #888;
            text-decoration: line-through;
            margin-left: 10px;
        }

        .add-to-cart {
            margin: 12px 18px 0;
            width: calc(100% - 36px);
            background: #1e2a3a;
            color: #fff;
            border: none;
            padding: 12px 0;
            border-radius: 60px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: 0.15s;
        }

        .add-to-cart:hover {
            background: #2d7a4a;
        }

        .add-to-cart i {
            margin-right: 8px;
        }

        /* SIDECART (carrito lateral) */
        .sidecart-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            z-index: 200;
            display: none;
            justify-content: flex-end;
            backdrop-filter: blur(2px);
        }

        .sidecart-overlay.open {
            display: flex;
        }

        .sidecart {
            background: #fff;
            width: 400px;
            max-width: 90vw;
            height: 100%;
            padding: 30px 24px;
            overflow-y: auto;
            box-shadow: -8px 0 30px rgba(0, 0, 0, 0.15);
            display: flex;
            flex-direction: column;
        }

        .sidecart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 16px;
            border-bottom: 1px solid #eee;
        }

        .sidecart-header h3 {
            font-size: 22px;
            font-weight: 700;
        }

        .sidecart-close {
            background: none;
            border: none;
            font-size: 28px;
            cursor: pointer;
            color: #888;
            transition: 0.15s;
        }

        .sidecart-close:hover {
            color: #1e1e1e;
        }

        .sidecart-items {
            flex: 1;
            margin: 16px 0;
            overflow-y: auto;
        }

        .cart-item {
            display: flex;
            gap: 14px;
            padding: 12px 0;
            border-bottom: 1px solid #f0f0f0;
            align-items: center;
        }

        .cart-item .item-img {
            width: 56px;
            height: 56px;
            background: #eef2f5;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: #2d7a4a;
            flex-shrink: 0;
        }

        .cart-item .item-details {
            flex: 1;
        }

        .cart-item .item-details .item-name {
            font-weight: 600;
            font-size: 15px;
        }

        .cart-item .item-details .item-price {
            font-weight: 700;
            color: #2d7a4a;
        }

        .cart-item .item-qty {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .cart-item .item-qty button {
            background: #f0f0f0;
            border: none;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            font-weight: 700;
            cursor: pointer;
            transition: 0.1s;
        }

        .cart-item .item-qty button:hover {
            background: #ddd;
        }

        .cart-item .item-qty span {
            font-weight: 600;
            min-width: 20px;
            text-align: center;
        }

        .cart-item .remove-item {
            color: #c0392b;
            background: none;
            border: none;
            font-size: 18px;
            cursor: pointer;
            padding: 0 4px;
        }

        .sidecart-footer {
            border-top: 1px solid #eee;
            padding-top: 18px;
        }

        .cart-total {
            display: flex;
            justify-content: space-between;
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 14px;
        }

        .checkout-btn {
            width: 100%;
            background: #2d7a4a;
            color: #fff;
            border: none;
            padding: 16px;
            border-radius: 60px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            transition: 0.15s;
        }

        .checkout-btn:hover {
            background: #1f5f38;
        }

        .empty-cart {
            text-align: center;
            color: #888;
            padding: 40px 0;
        }

        .empty-cart i {
            font-size: 48px;
            display: block;
            margin-bottom: 12px;
            opacity: 0.3;
        }

        /* FOOTER */
        footer {
            background: #1e2a3a;
            color: #d0d7dd;
            padding: 40px 30px 20px;
            margin-top: 20px;
            border-radius: 28px 28px 0 0;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .footer-grid h4 {
            color: #fff;
            margin-bottom: 12px;
            font-weight: 600;
        }

        .footer-grid p,
        .footer-grid a {
            color: #b0bbc5;
            text-decoration: none;
            line-height: 1.8;
            font-size: 14px;
        }

        .footer-grid a:hover {
            color: #a6e0b3;
        }

        .footer-bottom {
            text-align: center;
            border-top: 1px solid #2d3f54;
            padding-top: 20px;
            margin-top: 30px;
            font-size: 13px;
            color: #8899aa;
        }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            header {
                padding: 12px 16px;
            }
            nav {
                display: none;
            }
            .banner {
                padding: 30px 20px;
                margin: 10px 16px 20px;
                flex-direction: column;
                text-align: center;
            }
            .banner-text h2 {
                font-size: 30px;
            }
            .banner-image {
                font-size: 50px;
                padding: 20px;
            }
            .products-section {
                padding: 10px 16px 30px;
            }
            .products-grid {
                grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
                gap: 16px;
            }
            .product-img {
                height: 180px;
                font-size: 40px;
            }
            .sidecart {
                width: 100%;
                max-width: 100%;
            }
            .categories {
                gap: 10px;
                margin: 0 16px 20px;
            }
            .category-chip {
                padding: 8px 18px;
                font-size: 12px;
            }
            .footer-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @media (max-width: 480px) {
            .footer-grid {
                grid-template-columns: 1fr;
            }
            .banner-text h2 {
                font-size: 24px;
            }
            .products-grid {
                grid-template-columns: 1fr 1fr;
                gap: 12px;
            }
            .product-info h4 {
                font-size: 14px;
            }
            .product-info .price {
                font-size: 16px;
            }
        }

        /* Scroll */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f0f0f0;
        }
        ::-webkit-scrollbar-thumb {
            background: #2d7a4a;
            border-radius: 10px;
        }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header>
        <div class="logo">
            <i class="fas fa-tshirt"></i> URBAN <span>FIT</span>
        </div>
        <nav>
            <a href="#">Hombre</a>
            <a href="#">Mujer</a>
            <a href="#">Accesorios</a>
            <a href="#">Ofertas</a>
        </nav>
        <div class="header-actions">
            <i class="fas fa-search"></i>
            <i class="fas fa-user"></i>
            <div class="cart-icon" id="cartIcon">
                <i class="fas fa-shopping-bag"></i>
                <span class="cart-badge" id="cartBadge">0</span>
            </div>
        </div>
    </header>

    <!-- BANNER -->
    <div class="banner">
        <div class="banner-text">
            <h2>Nuevo <span>Streetwear</span><br />Temporada 2026</h2>
            <p>Descubre nuestra colección exclusiva con los diseños más urbanos y sostenibles.</p>
            <button class="banner-btn">Explorar ahora <i class="fas fa-arrow-right" style="margin-left:8px;"></i></button>
        </div>
        <div class="banner-image">
            <i class="fas fa-shoe-prints"></i>
            <i class="fas fa-hat-cowboy" style="margin-left:20px;"></i>
        </div>
    </div>

    <!-- CATEGORÍAS -->
    <div class="categories">
        <span class="category-chip active">Todo</span>
        <span class="category-chip">Hombre</span>
        <span class="category-chip">Mujer</span>
        <span class="category-chip">Accesorios</span>
        <span class="category-chip">Deportivo</span>
        <span class="category-chip">Ofertas</span>
    </div>

    <!-- PRODUCTOS -->
    <section class="products-section">
        <div class="section-header">
            <h3>Lo más vendido</h3>
            <span>12 productos</span>
        </div>
        <div class="products-grid" id="productsGrid">
            <!-- Los productos se inyectan con JS -->
        </div>
    </section>

    <!-- SIDECART (Carrito lateral) -->
    <div class="sidecart-overlay" id="sidecartOverlay">
        <div class="sidecart">
            <div class="sidecart-header">
                <h3><i class="fas fa-shopping-bag" style="color:#2d7a4a;"></i> Mi carrito</h3>
                <button class="sidecart-close" id="closeSidecart">&times;</button>
            </div>
            <div class="sidecart-items" id="sidecartItems">
                <div class="empty-cart">
                    <i class="fas fa-shopping-bag"></i>
                    Tu carrito está vacío
                </div>
            </div>
            <div class="sidecart-footer">
                <div class="cart-total">
                    <span>Total</span>
                    <span id="cartTotal">$0</span>
                </div>
                <button class="checkout-btn" id="checkoutBtn">
                    <i class="fas fa-lock"></i> Finalizar compra
                </button>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer>
        <div class="footer-grid">
            <div>
                <h4>URBAN FIT</h4>
                <p>Ropa urbana para los que viven al límite. Calidad y estilo en cada prenda.</p>
            </div>
            <div>
                <h4>Enlaces</h4>
                <a href="#">Hombre</a><br />
                <a href="#">Mujer</a><br />
                <a href="#">Accesorios</a><br />
                <a href="#">Ofertas</a>
            </div>
            <div>
                <h4>Atención</h4>
                <a href="#">Contacto</a><br />
                <a href="#">Envíos</a><br />
                <a href="#">Cambios</a><br />
                <a href="#">Preguntas frecuentes</a>
            </div>
            <div>
                <h4>Síguenos</h4>
                <a href="#"><i class="fab fa-instagram"></i> Instagram</a><br />
                <a href="#"><i class="fab fa-tiktok"></i> TikTok</a><br />
                <a href="#"><i class="fab fa-youtube"></i> YouTube</a>
            </div>
        </div>
        <div class="footer-bottom">
            &copy; 2026 URBAN FIT · Todos los derechos reservados
        </div>
    </footer>

    <script>
        // ============================================================
        //  DATOS DE PRODUCTOS
        // ============================================================
        const productos = [{
            id: 1,
            nombre: 'Camiseta Oversize "Essence"',
            categoria: 'Hombre',
            precio: 14990,
            precioOferta: null,
            icono: 'fa-tshirt'
        }, {
            id: 2,
            nombre: 'Pantalón Cargo Urban',
            categoria: 'Hombre',
            precio: 25990,
            precioOferta: 19990,
            icono: 'fa-user-tie'
        }, {
            id: 3,
            nombre: 'Chaqueta Denim Clásica',
            categoria: 'Mujer',
            precio: 39990,
            precioOferta: null,
            icono: 'fa-jacket'
        }, {
            id: 4,
            nombre: 'Top Deportivo Tech',
            categoria: 'Mujer',
            precio: 18990,
            precioOferta: 14990,
            icono: 'fa-vest'
        }, {
            id: 5,
            nombre: 'Gorra Snapback Original',
            categoria: 'Accesorios',
            precio: 9990,
            precioOferta: null,
            icono: 'fa-hat-cowboy'
        }, {
            id: 6,
            nombre: 'Mochila Urbana 20L',
            categoria: 'Accesorios',
            precio: 27990,
            precioOferta: 22990,
            icono: 'fa-bag-shopping'
        }, {
            id: 7,
            nombre: 'Polera Manga Larga "Core"',
            categoria: 'Hombre',
            precio: 16990,
            precioOferta: 12990,
            icono: 'fa-tshirt'
        }, {
            id: 8,
            nombre: 'Short Deportivo Cómodo',
            categoria: 'Mujer',
            precio: 13990,
            precioOferta: null,
            icono: 'fa-vest'
        }, {
            id: 9,
            nombre: 'Set Deportivo (Top + Leggings)',
            categoria: 'Mujer',
            precio: 45990,
            precioOferta: 37990,
            icono: 'fa-person-running'
        }];

        // ============================================================
        //  ESTADO DEL CARRITO
        // ============================================================
        let cart = [];
        let cartTotal = 0;

        // ============================================================
        //  DOM REFS
        // ============================================================
        const productsGrid = document.getElementById('productsGrid');
        const cartBadge = document.getElementById('cartBadge');
        const sidecartOverlay = document.getElementById('sidecartOverlay');
        const sidecartItems = document.getElementById('sidecartItems');
        const cartTotalSpan = document.getElementById('cartTotal');
        const closeSidecart = document.getElementById('closeSidecart');
        const cartIcon = document.getElementById('cartIcon');
        const checkoutBtn = document.getElementById('checkoutBtn');

        // ============================================================
        //  RENDER PRODUCTOS
        // ============================================================
        function renderProducts() {
            productsGrid.innerHTML = '';
            productos.forEach(p => {
                const card = document.createElement('div');
                card.className = 'product-card';

                // Imagen
                const imgDiv = document.createElement('div');
                imgDiv.className = 'product-img';
                imgDiv.innerHTML = `<i class="fas ${p.icono}"></i>`;
                card.appendChild(imgDiv);

                // Info
                const info = document.createElement('div');
                info.className = 'product-info';
                info.innerHTML = `
                    <h4>${p.nombre}</h4>
                    <div class="category-tag">${p.categoria}</div>
                    <div class="price">
                        $${p.precio.toLocaleString('es-CL')}
                        ${p.precioOferta ? `<small>$${p.precioOferta.toLocaleString('es-CL')}</small>` : ''}
                    </div>
                `;
                card.appendChild(info);

                // Botón
                const btn = document.createElement('button');
                btn.className = 'add-to-cart';
                btn.innerHTML = `<i class="fas fa-plus"></i> Agregar`;
                btn.addEventListener('click', () => addToCart(p.id));
                card.appendChild(btn);

                productsGrid.appendChild(card);
            });
        }

        // ============================================================
        //  CARRITO
        // ============================================================
        function addToCart(productId) {
            const product = productos.find(p => p.id === productId);
            if (!product) return;

            const existing = cart.find(item => item.id === productId);
            if (existing) {
                existing.cantidad += 1;
            } else {
                cart.push({
                    id: product.id,
                    nombre: product.nombre,
                    precio: product.precioOferta || product.precio,
                    cantidad: 1,
                    icono: product.icono
                });
            }
            updateCartUI();
            openSidecart();
        }

        function removeFromCart(productId) {
            const index = cart.findIndex(item => item.id === productId);
            if (index !== -1) {
                cart.splice(index, 1);
                updateCartUI();
            }
        }

        function changeQty(productId, delta) {
            const item = cart.find(i => i.id === productId);
            if (!item) return;
            item.cantidad += delta;
            if (item.cantidad <= 0) {
                removeFromCart(productId);
                return;
            }
            updateCartUI();
        }

        function updateCartUI() {
            // Badge
            const totalItems = cart.reduce((acc, i) => acc + i.cantidad, 0);
            cartBadge.textContent = totalItems;

            // Render carrito lateral
            if (cart.length === 0) {
                sidecartItems.innerHTML = `
                    <div class="empty-cart">
                        <i class="fas fa-shopping-bag"></i>
                        Tu carrito está vacío
                    </div>
                `;
                cartTotalSpan.textContent = '$0';
                return;
            }

            let html = '';
            let total = 0;
            cart.forEach(item => {
                const subtotal = item.precio * item.cantidad;
                total += subtotal;
                html += `
                    <div class="cart-item">
                        <div class="item-img"><i class="fas ${item.icono}"></i></div>
                        <div class="item-details">
                            <div class="item-name">${item.nombre}</div>
                            <div class="item-price">$${item.precio.toLocaleString('es-CL')}</div>
                        </div>
                        <div class="item-qty">
                            <button onclick="changeQty(${item.id}, -1)">−</button>
                            <span>${item.cantidad}</span>
                            <button onclick="changeQty(${item.id}, 1)">+</button>
                        </div>
                        <button class="remove-item" onclick="removeFromCart(${item.id})"><i class="fas fa-times"></i></button>
                    </div>
                `;
            });
            sidecartItems.innerHTML = html;
            cartTotalSpan.textContent = `$${total.toLocaleString('es-CL')}`;
            cartTotal = total;
        }

        // ============================================================
        //  SIDECART TOGGLE
        // ============================================================
        function openSidecart() {
            sidecartOverlay.classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeSidecartFn() {
            sidecartOverlay.classList.remove('open');
            document.body.style.overflow = '';
        }

        cartIcon.addEventListener('click', openSidecart);
        closeSidecart.addEventListener('click', closeSidecartFn);
        sidecartOverlay.addEventListener('click', (e) => {
            if (e.target === sidecartOverlay) closeSidecartFn();
        });

        // ============================================================
        //  CHECKOUT (simulación)
        // ============================================================
        checkoutBtn.addEventListener('click', () => {
            if (cart.length === 0) {
                alert('Tu carrito está vacío. Agrega productos primero.');
                return;
            }
            alert(`¡Compra realizada con éxito! Total: $${cartTotal.toLocaleString('es-CL')}\nGracias por confiar en URBAN FIT.`);
            cart = [];
            updateCartUI();
            closeSidecartFn();
        });

        // ============================================================
        //  CATEGORÍAS (filtro visual)
        // ============================================================
        document.querySelectorAll('.category-chip').forEach(chip => {
            chip.addEventListener('click', function() {
                document.querySelectorAll('.category-chip').forEach(c => c.classList.remove('active'));
                this.classList.add('active');
                // Aquí se podría implementar filtro real, pero es demo visual
            });
        });

        // ============================================================
        //  INICIALIZAR
        // ============================================================
        renderProducts();
        updateCartUI();

        // Hacer funciones globales para onclick en los botones del carrito
        window.addToCart = addToCart;
        window.removeFromCart = removeFromCart;
        window.changeQty = changeQty;
        window.openSidecart = openSidecart;
        window.closeSidecartFn = closeSidecartFn;
    </script>

</body>
</html>
